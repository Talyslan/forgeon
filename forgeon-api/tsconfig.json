{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",

        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "es2024",

        "strict": true,
        "jsx": "react-jsx",
        "verbatimModuleSyntax": true,
        "isolatedModules": true,
        "noUncheckedSideEffectImports": true,
        "moduleDetection": "force",
        "skipLibCheck": true
    },
    "include": ["src"]
}
