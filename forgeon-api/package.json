{
    "name": "forgeon",
    "version": "1.0.0",
    "description": "AI-powered web application for generating and managing personalized workout plans for athletes and trainers.",
    "type": "module",
    "scripts": {
        "dev": "tsx --watch src/server.ts",
        "build": "pnpm exec prisma generate && esbuild src/server.ts --bundle --platform=node --format=esm --outfile=dist/server.js --external:@prisma/client --external:prisma --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\""
    },
    "engines": {
        "node": "24.x"
    },
    "keywords": [],
    "author": "Talyslan Canabarro",
    "license": "MIT",
    "packageManager": "pnpm@10.31.0",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.3.3",
        "dotenv": "^17.3.1",
        "esbuild": "^0.25.0",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "prisma": "^7.4.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    },
    "dependencies": {
        "@ai-sdk/google": "^3.0.43",
        "@ai-sdk/openai": "^3.0.41",
        "@fastify/cors": "^11.2.0",
        "@fastify/swagger": "^9.7.0",
        "@fastify/swagger-ui": "^5.2.5",
        "@prisma/adapter-pg": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "@scalar/fastify-api-reference": "^1.46.4",
        "ai": "^6.0.116",
        "better-auth": "^1.5.2",
        "dayjs": "^1.11.19",
        "fastify": "^5.7.4",
        "fastify-type-provider-zod": "^6.1.0",
        "pino-pretty": "^13.1.3",
        "zod": "^4.3.6"
    }
}
